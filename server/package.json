{
  "name": "jobtrack-hk-server",
  "version": "1.0.0",
  "description": "JobTrack HK backend — Express + SQLite",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "bench": "node scripts/bench.js"
  },
  "dependencies": {
    "better-sqlite3": "11.5.0",
    "cors": "2.8.5",
    "express": "4.21.2"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "nodemon": "3.1.7",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "routes/**/*.js",
      "db.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "statements": 80,
        "functions": 80,
        "branches": 70
      }
    }
  }
}
